<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for a file or directory that exists in /dist, serve it from there
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Rewrite all requests to /dist/
  RewriteRule ^(.*)$ /dist/$1 [L]

  # Try to serve .html files if they exist
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.*)$ /dist/$1.html [L]
</IfModule>

# Disable directory listing
Options -Indexes
